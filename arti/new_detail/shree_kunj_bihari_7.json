{
    "title": "आरती श्री यशोदालाल जी की",
    "en_title": "Jai Kunj Bihari",
    "deity": "श्री यशोदालाल आरती",
    "deity_id": "krishna",
    "audio_file": "shree-kunj-bihari-aarti.mp3",
    "verses": [
        [
            "आरति करत यसोदा प्रमुदित, फूली अङ्ग न मात |",
            "बल-बल कहि दुलरावत ||"
        ],
        [
            "आनन्द मगन भई पुलकात |",
            "सुबरन-थार रत्न-दीपावलि ||"
        ],
        [
            "चित्रित घृत-भीनी बात |",
            "कल सिन्दूर दूब दधि ||"
        ],
        [
            "अच्छत तिलक करत बहु भाँत |",
            "अन्न चतुर्विध बिबिध ||"
        ],
        [
            "भोग दुन्दुभि बाजत बहु जात |",
            "नाचत गोप कुम्कुमा ||"
        ],
        [
            "छिरकत देत अखिल नगदात |",
            "बरसत कुसुम निकर-सुर-नर- ||"
        ],
        [
            "मुनि व्रजजुवती मुसकात |",
            "कृष्णदास-प्रभु गिरधर को ||"
        ],
        [
            "मुख निरख लजत ससि-काँत |",
            "मुख निरख लजत ससि-काँत ||"
        ]
    ]
}